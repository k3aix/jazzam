{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "StandardsService": {
    "BaseUrl": "http://localhost:3001"
  },
  "SearchAlgorithm": {
    "MinimumIntervals": 5,
    "DefaultErrorTolerance": 0.30,
    "DefaultMinConfidence": 0.40,
    "EnablePositionBias": true,
    "DefaultPitchWeight": 0.6,
    "RhythmErrorTolerance": 0.35,
    "EnhancedScoring": {
      "Enabled": true,
      "ConsecutiveMissThreshold": 3,
      "ConsecutiveMissPenalty": 0.12
    },
    "CorrectionDetection": {
      "Enabled": true,
      "MaxWidth": 2,
      "MaxDuration": 8,
      "MaxSequenceLength": 10,
      "MaxCorrectionRate": 0.20
    },
    "CompressedSearch": {
      "Enabled": true,
      "ConfidencePenalty": 0.15,
      "MinRunLength": 4
    }
  }
}
